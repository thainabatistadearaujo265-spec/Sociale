rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - niche: string
    //   - plan: string ('free' or 'premium')
    //   - dailyUsageCount: number
    //   - lastUsageDate: string (YYYY-MM-DD)
    //   - createdAt: timestamp
    //
    // Collection: saved_content
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required)
    //   - type: string ('post', 'video', 'idea', 'bio', 'hashtag', 'calendar')
    //   - theme: string
    //   - content: map (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'plan']) &&
             data.uid is string &&
             data.email is string &&
             data.plan in ['free', 'premium'];
    }

    function isValidContent(data) {
      return data.keys().hasAll(['uid', 'type', 'content', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.type in ['post', 'video', 'idea', 'bio', 'hashtag', 'calendar'] &&
             data.content is map &&
             data.createdAt is timestamp;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              (request.auth.token.email == "thainabatistadearaujo265@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.plan == resource.data.plan) || isAdmin();
    }

    match /saved_content/{contentId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidContent(request.resource.data);
      allow update: if isDocOwner() && isValidContent(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
